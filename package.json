{
  "name": "jenkins-multicontainer-app",
  "version": "1.0.0",
  "description": "Aplicación con pruebas multi-contenedor usando PostgreSQL y Redis",
  "main": "src/app.js",
  "scripts": {
    "test:unit": "jest tests/unit --coverage --runInBand",
    "test:integration": "jest tests/integration --coverage --runInBand",
    "test:all": "npm run test:unit && npm run test:integration",
    "start": "node src/app.js"
  },
  "dependencies": {
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "redis": "^4.6.5"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.3"
  },
  "jest-junit": {
    "outputDirectory": "coverage",
    "outputName": "junit.xml"
  }
}